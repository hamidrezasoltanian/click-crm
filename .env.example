PORT=3000

# PostgreSQL connection
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=atena_crm
PG_USER=atena_app        # use a dedicated DB user, NOT postgres superuser
PG_PASSWORD=yourpassword

# JWT signing secret — MUST be changed before deploying
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-random-secret-string

# Default passwords set during first-time DB seeding (only used if users table is empty)
ADMIN_PASSWORD=admin123
DEFAULT_USER_PASSWORD=Atena@1234

# Anthropic API key (optional — if set here, takes priority over DB setting and is never sent to clients)
# ANTHROPIC_API_KEY=sk-ant-...
